# OpenAI API key for summaries and embeddings
OPENAI_API_KEY=sk-...

# Override config file path
LITERAVORE_CONFIG=config/default.yml

# Enable dev mode (keeps PDFs, uses smaller batches)
LITERAVORE_DEV_MODE=false

# Override data directory
LITERAVORE_DATA_DIR=data

# Override storage backend (local or s3)
LITERAVORE_STORAGE_BACKEND=local

# S3 configuration (when storage backend is s3)
LITERAVORE_S3_ENDPOINT=
LITERAVORE_S3_BUCKET=
LITERAVORE_S3_ACCESS_KEY=
LITERAVORE_S3_SECRET_KEY=
